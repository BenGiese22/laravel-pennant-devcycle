# DevCycle Server SDK key (used by the Pennant driver)
DEVCYCLE_SERVER_SDK_KEY=

# Optional: SDK key used by the live debug test
DEVCYCLE_LIVE_SDK_KEY=

# Management API credentials (used by the optional REST routes)
DEVCYCLE_MGMT_CLIENT_ID=
DEVCYCLE_MGMT_CLIENT_SECRET=
DEVCYCLE_MGMT_PROJECT_KEY=
DEVCYCLE_MGMT_API_BASE=https://api.devcycle.com
DEVCYCLE_MGMT_AUTH_BASE=https://auth.devcycle.com
